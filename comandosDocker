# Build com Java 17
docker build -t msendereco:1.0-java17 .

# Executar container
docker run -p 8080:8080 \
  -e SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/root \
  -e SPRING_DATASOURCE_USERNAME=root \
  -e SPRING_DATASOURCE_PASSWORD=root \
  msendereco:1.0-java17

# Com docker-compose
docker-compose up -d

# Ver logs
docker-compose logs -f app

# Parar
docker-compose down